cell_type":"code","source":["weather_desc = {\n","    1: 'Ясно/Хмарно',\n","    2: 'Туман',\n","    3: 'Легкий дощ/сніг',\n","    4: 'Сильний дощ/сніг'\n","}\n","\n","df['weather_name'] = df['weather'].map(weather_desc)\n","\n","plt.figure(figsize=(12, 6))\n","\n","data_to_plot = [df[df['weather'] == i]['count'] for i in sorted(df['weather'].unique())]\n","labels = [weather_desc[i] for i in sorted(df['weather'].unique())]\n","\n","box = plt.boxplot(data_to_plot,\n","                  vert=False,\n","                  patch_artist=True,\n","                  labels=labels)\n","\n","colors = ['gold', 'lightblue', 'lightgray', 'navy']\n","for patch, color in zip(box['boxes'], colors):\n","    patch.set_facecolor(color)\n","\n","plt.title('Розподіл кількості оренди за погодними умовами', fontsize=16)\n","plt.xlabel('Кількість оренд', fontsize=14)\n","plt.ylabel('Погодні умови', fontsize=14)\n","plt.grid(True, alpha=0.3, axis='x')\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"=\"*60)\n","print(\"ВІДПОВІДІ НА ПИТАННЯ\")\n","print(\"=\"*60)\n","\n","print(\"\\n📊 Аналіз розкиду даних:\")\n","for weather in sorted(df['weather'].unique()):\n","    data = df[df['weather'] == weather]['count']\n","    print(f\"\\n{weather_desc[weather]}:\")\n","    print(f\"   Мінімум: {data.min()}\")\n","    print(f\"   Максимум: {data.max()}\")\n","    print(f\"   Розкид: {data.max() - data.min()}\")\n","    print(f\"   Медіана: {data.median():.0f}\")\n","\n","weather_ranges = {}\n","for weather in sorted(df['weather'].unique()):\n","    data = df[df['weather'] == weather]['count']\n","    weather_ranges[weather] = data.max() - data.min()\n","\n","max_range_weather = max(weather_ranges, key=weather_ranges.get)\n","print(f\"\\n1. Найбільший розкид: {weather_desc[max_range_weather]}\")\n","\n","print(\"\\n2. Аналіз викидів (outliers):\")\n","for weather in sorted(df['weather'].unique()):\n","    data = df[df['weather'] == weather]['count']\n","    Q1 = data.quantile(0.25)\n","    Q3 = data.quantile(0.75)\n","    IQR = Q3 - Q1\n","    lower_bound = Q1 - 1.5 * IQR\n","    upper_bound = Q3 + 1.5 * IQR\n","\n","    outliers = data[(data < lower_bound) | (data > upper_bound)]\n","    print(f\"   {weather_desc[weather]}: {len(outliers)} викидів\")\n","\n","medians = {}\n","for weather in sorted(df['weather'].unique()):\n","    medians[weather] = df[df['weather'] == weather]['count'].median()\n","\n","max_median_weather = max(medians, key=medians.get)\n","print(f\"\\n3. Найвище медіанне значення: {weather_desc[max_median_weather]} ({medians[max_median_weather]:.0f} оренд)\")"],"metadata":{"id":"GCNY6dvk9XoY","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1772367036584,"user_tz":-240,"elapsed":170,"user":{"displayName":"Olya Rakhimova","userId":"16165915298025910943"}},"outputId":"8d37eecf-b26a-4ef4-f759-06bc2fbfb053"},"id":"GCNY6dvk9XoY","execution_count":87,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-391/164202860.py:15: MatplotlibDeprecationWarning: The 'labels' parameter of boxplot() has been renamed 'tick_labels' since Matplotlib 3.9; support for the old name will be dropped in 3.11.\n","  box = plt.boxplot(data_to_plot,\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["============================================================\n","ВІДПОВІДІ НА ПИТАННЯ\n","============================================================\n","\n","📊 Аналіз розкиду даних:\n","\n","Ясно/Хмарно:\n","   Мінімум: 1\n","   Максимум: 977\n","   Розкид: 976\n","   Медіана: 161\n","\n","Туман:\n","   Мінімум: 1\n","   Максимум: 890\n","   Розкид: 889\n","   Медіана: 134\n","\n","Легкий дощ/сніг:\n","   Мінімум: 1\n","   Максимум: 891\n","   Розкид: 890\n","   Медіана: 71\n","\n","Сильний дощ/сніг:\n","   Мінімум: 164\n","   Максимум: 164\n","   Розкид: 0\n","   Ме